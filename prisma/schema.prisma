generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Note {
  id            String               @id @default(cuid())
  userId        String
  title         String               @default("")
  content       String               @default("")
  tags          String               @default("[]")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  shareLinks      ShareLink[]
  collaborators   NoteCollaborator[]
  accessRequests  AccessRequest[]
  comments        Comment[]

  @@index([userId])
}

model Comment {
  id          String    @id @default(cuid())
  noteId      String
  note        Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  userId      String
  userName    String    @default("")
  userAvatar  String    @default("")
  content     String
  parentId    String?
  parent      Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[] @relation("CommentReplies")
  commentId   String    @default("")
  resolved    Boolean   @default(false)
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([noteId])
  @@index([parentId])
  @@index([commentId])
}

model NoteCollaborator {
  id          String   @id @default(cuid())
  noteId      String
  note        Note     @relation(fields: [noteId], references: [id], onDelete: Cascade)
  userId      String
  username    String   @default("")
  displayName String   @default("")
  avatarUrl   String   @default("")
  permission  String   @default("READ")
  invitedAt   DateTime @default(now())

  @@unique([noteId, userId])
  @@index([noteId])
  @@index([userId])
}

model ShareLink {
  id         String    @id @default(cuid())
  token      String    @unique
  noteId     String
  note       Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  permission String    @default("READ")
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?

  @@index([token])
  @@index([noteId])
}

model SharedAccess {
  id          String   @id @default(cuid())
  userId      String
  noteId      String
  noteTitle   String   @default("")
  token       String
  permission  String
  ownerName   String   @default("")
  lastSeen    DateTime @default(now())

  @@unique([userId, noteId])
  @@index([userId])
}

model Notification {
  id          String    @id @default(cuid())
  userId      String
  type        String    // mention, shared, deleted, permission_changed, opened, access_request, access_response
  noteId      String?
  noteTitle   String    @default("")
  message     String
  fromUserId  String?
  fromName    String    @default("")
  fromAvatar  String    @default("")
  metadata    String    @default("{}")
  read        Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

model AccessRequest {
  id               String    @id @default(cuid())
  noteId           String
  note             Note      @relation(fields: [noteId], references: [id], onDelete: Cascade)
  requesterId      String
  requesterName    String    @default("")
  requesterAvatar  String    @default("")
  status           String    @default("pending")
  resolvedBy       String?
  resolvedByName   String?
  grantedPermission String?
  createdAt        DateTime  @default(now())
  resolvedAt       DateTime?

  @@unique([noteId, requesterId])
  @@index([noteId])
  @@index([requesterId])
}
